# Copy to .env and fill in only to opt into an LLM. NEVER commit .env.
# The default is offline: scan, challenge generation, and verification still run.
REDCELL_LLM_PROVIDER=offline

# Optional Gemini configuration. Redcell uses Gemini's OpenAI-compatible endpoint.
GEMINI_API_KEY=

# Optional OpenAI configuration.
OPENAI_API_KEY=sk-...

# Set these when opting into a provider.
REDCELL_MODEL_STRONG=gpt-5.3-codex
REDCELL_MODEL_CHEAP=gpt-5.6-luna
